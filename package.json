{
  "name": "hft-elon-bot",
  "version": "0.0.1",
  "private": true,
  "description": "Polymarket Elon-tweet market sniper (CLOB V2 + pUSD)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "smoke": "tsx scripts/test-connection.ts",
    "simulate": "tsx scripts/simulate-snipe.ts",
    "stats": "tsx scripts/stats.ts",
    "latency": "tsx scripts/latency.ts",
    "health": "tsx scripts/health-check.ts",
    "setup-creds": "tsx scripts/setup-creds.ts",
    "check-live": "tsx scripts/check-live.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@polymarket/clob-client-v2": "^1.0.6",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "undici": "^7.0.0",
    "viem": "^2.46.3",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.4"
  }
}
